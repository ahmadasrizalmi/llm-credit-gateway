{
  "name": "llm-credit-gateway",
  "private": true,
  "version": "0.1.0",
  "workspaces": ["apps/*"],
  "scripts": {
    "dev:worker": "npm --workspace apps/worker run dev",
    "dev:web": "npm --workspace apps/web run dev",
    "build": "npm run build --workspaces",
    "typecheck": "npm run typecheck --workspaces",
    "test": "npm --workspace apps/worker run test",
    "db:migrate:local": "npm --workspace apps/worker run db:migrate:local",
    "db:migrate:remote": "npm --workspace apps/worker run db:migrate:remote"
  }
}
