{
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "aipmmi",
  "main": "src/index.ts",
  "compatibility_date": "2026-07-22",
  "observability": { "enabled": true },
  "vars": {
    "CORS_ORIGINS": "http://localhost:5173,https://tokenroute.pondokmultimediamunzalan.workers.dev",
    "DEFAULT_ORG_ID": "org_default"
  },
  "d1_databases": [
    {
      "binding": "DB",
      "database_name": "llm-credit-gateway",
      "database_id": "903cfa92-c303-4aac-b6f2-68a43ba126ac",
      "migrations_dir": "migrations"
    }
  ],
  "triggers": {
    "crons": ["*/15 * * * *"]
  }
}
